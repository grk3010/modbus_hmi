[Port]
        Object_Name = "Port Object";
        Object_Class_Code = 0xF4;
        Port1 =
                TCP,                    $ Port type
                "TCP/IP",               $ Port name
                "20 F5 24 01",          $ Path to object supporting this port
                1,                      $ Internal Port Number
				0;
$
[Capacity]
        ConnOverhead = .1;
        MaxIOConnections = 3;           $ Maximum number of Encapsulation sessions (class 1)
        MaxMsgConnections = 7;          $ Maximum number of CIP connections (class 3)
        MaxConsumersPerMcast = 1;
        TSpec1 = TxRx, 500, 1020;

$  
[TCP/IP Interface Class]
        Revision = 4;
        Object_Name = "TCP/IP Interface Object";
        Object_Class_Code = 0xF5;
        MaxInst = 1;
        Number_Of_Static_Instances = 1;
        Max_Number_Of_Dynamic_Instances = 0;
        ENetQCT1 =
                150,                    $ Ready for Connection Time
                20;                     $ Accumulated CIP Connection Time

$  
[Ethernet Link Class]
        Revision = 4;
        Object_Name = "Ethernet Link Object";
        Object_Class_Code = 0xF6;
        MaxInst = 3;
        Number_Of_Static_Instances = 2;
        Max_Number_Of_Dynamic_Instances = 0;
        InterfaceLabel1 = "ETH1";
        InterfaceLabel2 = "ETH2";
        InterfaceType1 = 2;             $ Twisted pair
        InterfaceType2 = 2;             $ Twisted pair

